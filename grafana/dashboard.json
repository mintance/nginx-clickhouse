{
  "__inputs": [
    {
      "name": "DS_CLICKHOUSE",
      "label": "ClickHouse",
      "description": "ClickHouse data source",
      "type": "datasource",
      "pluginId": "grafana-clickhouse-datasource",
      "pluginName": "ClickHouse"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "grafana-clickhouse-datasource",
      "name": "ClickHouse",
      "version": "4.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "NGINX access log analytics powered by nginx-clickhouse",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Requests",
      "type": "stat",
      "targets": [
        {
          "rawSql": "SELECT count(*) as total FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime)",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Requests per Second",
      "type": "stat",
      "targets": [
        {
          "rawSql": "SELECT count(*) / greatest(dateDiff('second', min(TimeLocal), max(TimeLocal)), 1) as rps FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime)",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        {
          "rawSql": "SELECT countIf(Status >= 500) * 100.0 / greatest(count(*), 1) as error_rate FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime)",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Avg Response Time",
      "type": "stat",
      "targets": [
        {
          "rawSql": "SELECT avg(RequestTime) as avg_time FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime)",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "P95 Response Time",
      "type": "stat",
      "targets": [
        {
          "rawSql": "SELECT quantile(0.95)(RequestTime) as p95 FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime)",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "P99 Response Time",
      "type": "stat",
      "targets": [
        {
          "rawSql": "SELECT quantile(0.99)(RequestTime) as p99 FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime)",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisLabel": "", "barAlignment": 0, "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 0, "stacking": { "group": "A", "mode": "normal" } },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "3xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "id": 7,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Requests by Status Class",
      "type": "timeseries",
      "targets": [
        {
          "rawSql": "SELECT toStartOfInterval(TimeLocal, INTERVAL $__interval_s second) as time, concat(toString(intDiv(Status, 100)), 'xx') as status_class, count(*) as cnt FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime) GROUP BY time, status_class ORDER BY time",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 8,
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }, "pieType": "donut", "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }, "tooltip": { "mode": "single" } },
      "title": "Requests by Method",
      "type": "piechart",
      "targets": [
        {
          "rawSql": "SELECT splitByChar(' ', Request)[1] as method, count(*) as cnt FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime) GROUP BY method ORDER BY cnt DESC",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "axisCenteredZero": false, "axisLabel": "seconds", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "pointSize": 5, "showPoints": "never" },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 9,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Response Time (Avg / P95 / P99)",
      "type": "timeseries",
      "targets": [
        {
          "rawSql": "SELECT toStartOfInterval(TimeLocal, INTERVAL $__interval_s second) as time, avg(RequestTime) as avg, quantile(0.95)(RequestTime) as p95, quantile(0.99)(RequestTime) as p99 FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime) GROUP BY time ORDER BY time",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never" },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "targets": [
        {
          "rawSql": "SELECT toStartOfInterval(TimeLocal, INTERVAL $__interval_s second) as time, countIf(Status >= 400) * 100.0 / greatest(count(*), 1) as error_4xx_5xx, countIf(Status >= 500) * 100.0 / greatest(count(*), 1) as error_5xx FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime) GROUP BY time ORDER BY time",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 11,
      "options": { "legend": { "calcs": ["sum", "mean"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Bandwidth (Bytes Sent)",
      "type": "timeseries",
      "targets": [
        {
          "rawSql": "SELECT toStartOfInterval(TimeLocal, INTERVAL $__interval_s second) as time, sum(BytesSent) as bytes_sent FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime) GROUP BY time ORDER BY time",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Requests per Second Over Time",
      "type": "timeseries",
      "targets": [
        {
          "rawSql": "SELECT toStartOfInterval(TimeLocal, INTERVAL $__interval_s second) as time, count(*) / $__interval_s as rps FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime) GROUP BY time ORDER BY time",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "Top N Analysis",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 80 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 32 },
      "id": 13,
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } },
      "title": "Top 10 URLs",
      "type": "barchart",
      "targets": [
        {
          "rawSql": "SELECT splitByChar(' ', Request)[2] as url, count(*) as cnt FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime) GROUP BY url ORDER BY cnt DESC LIMIT 10",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 80 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "id": 14,
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } },
      "title": "Top 10 Client IPs",
      "type": "barchart",
      "targets": [
        {
          "rawSql": "SELECT RemoteAddr as ip, count(*) as cnt FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime) GROUP BY ip ORDER BY cnt DESC LIMIT 10",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false, "fillOpacity": 80 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "id": 15,
      "options": { "legend": { "displayMode": "hidden" }, "tooltip": { "mode": "single" } },
      "title": "Top 10 User Agents",
      "type": "barchart",
      "targets": [
        {
          "rawSql": "SELECT HttpUserAgent as ua, count(*) as cnt FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime) GROUP BY ua ORDER BY cnt DESC LIMIT 10",
          "refId": "A",
          "format": 1
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 104,
      "title": "Slow & Error Requests",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Status" }, "properties": [{ "id": "custom.width", "value": 60 }] },
          { "matcher": { "id": "byName", "options": "RequestTime" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "custom.width", "value": 100 }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 41 },
      "id": 16,
      "options": { "showHeader": true, "sortBy": [{ "desc": true, "displayName": "RequestTime" }], "footer": { "enablePagination": true } },
      "title": "Slow & Error Requests",
      "type": "table",
      "targets": [
        {
          "rawSql": "SELECT TimeLocal, RemoteAddr, splitByChar(' ', Request)[1] as Method, splitByChar(' ', Request)[2] as URL, Status, BytesSent, RequestTime, HttpReferer, HttpUserAgent FROM ${database:String}.${table:String} WHERE TimeLocal >= toDateTime($__fromTime) AND TimeLocal <= toDateTime($__toTime) AND (Status >= 400 OR RequestTime > 1) ORDER BY TimeLocal DESC LIMIT 500",
          "refId": "A",
          "format": 1
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["nginx", "clickhouse", "nginx-clickhouse"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "metrics", "value": "metrics" },
        "description": "ClickHouse database name",
        "hide": 0,
        "label": "Database",
        "name": "database",
        "options": [],
        "query": "metrics",
        "type": "textbox"
      },
      {
        "current": { "selected": false, "text": "nginx", "value": "nginx" },
        "description": "ClickHouse table name",
        "hide": 0,
        "label": "Table",
        "name": "table",
        "options": [],
        "query": "nginx",
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "NGINX Access Logs",
  "uid": "nginx-clickhouse",
  "version": 1
}
